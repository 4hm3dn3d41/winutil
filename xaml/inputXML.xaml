<Window x:Class="WinUtility.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinUtility"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        WindowStyle="None"
        Width="Auto"
        Height="Auto"
        MinWidth="1000"
        MinHeight="600"
        AllowsTransparency="True"
        Title="WinUtil"
        Background="Transparent">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="8" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <!-- ── GLOBAL STYLES ── -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource ToolTipBackgroundColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ToolTipForegroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ToolTipBorderColor}"/>
            <Setter Property="MaxWidth" Value="{DynamicResource ToolTipWidth}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── SCROLLBAR STYLES ── -->
        <Style x:Key="ScrollThumbs" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid>
                            <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Fill="Transparent"/>
                            <Border x:Name="Rectangle1" CornerRadius="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{TemplateBinding Background}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Horizontal">
                                <Setter TargetName="Rectangle1" Property="Width" Value="Auto"/>
                                <Setter TargetName="Rectangle1" Property="Height" Value="6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
            <Setter Property="Foreground" Value="{DynamicResource ScrollBarFillColor}"/>
            <Setter Property="Background" Value="{DynamicResource ScrollBarTrackColor}"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Width="8" Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.00001*"/>
                            </Grid.RowDefinitions>
                            <Track x:Name="PART_Track" Grid.Row="0" IsDirectionReversed="true" Focusable="false">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="{TemplateBinding Foreground}" Style="{DynamicResource ScrollThumbs}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="Thumb" Property="IsMouseOver" Value="true">
                                <Setter Value="{DynamicResource ScrollBarFillHoverColor}" TargetName="Thumb" Property="Background"/>
                            </Trigger>
                            <Trigger SourceName="Thumb" Property="IsDragging" Value="true">
                                <Setter Value="{DynamicResource ScrollBarFillPressedColor}" TargetName="Thumb" Property="Background"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="Thumb" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="GridRoot" Property="LayoutTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="-90"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="PART_Track" Property="LayoutTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="-90"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="8"/>
                                <Setter TargetName="Thumb" Property="Tag" Value="Horizontal"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── FLUENT TEXT STYLES ── -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="HoverTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LinkForegroundColor}"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource LinkHoverForegroundColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource HeaderFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
        </Style>

        <Style x:Key="SubHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource SubHeaderFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
        </Style>

        <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource SectionHeaderFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundColor}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource CaptionFontSize}"/>
            <Setter Property="Foreground" Value="{DynamicResource TertiaryForegroundColor}"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource LabelboxForegroundColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
        </Style>

        <Style x:Key="labelfortweaks" TargetType="{x:Type Label}">
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── FLUENT BUTTON STYLES ── -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="{DynamicResource ButtonMargin}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundColor}"/>
            <Setter Property="Height" Value="{DynamicResource ButtonHeight}"/>
            <Setter Property="MinWidth" Value="{DynamicResource ButtonWidth}"/>
            <Setter Property="FontSize" Value="{DynamicResource ButtonFontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource ButtonFontFamily}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColor}"/>
            <Setter Property="BorderThickness" Value="{DynamicResource ButtonBorderThickness}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BackgroundBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource ButtonCornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0,12,0" RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundPressedColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource SurfaceLow}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="{DynamicResource ButtonMargin}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundColor}"/>
            <Setter Property="Height" Value="{DynamicResource ButtonHeight}"/>
            <Setter Property="MinWidth" Value="{DynamicResource ButtonWidth}"/>
            <Setter Property="FontSize" Value="{DynamicResource ButtonFontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource ButtonFontFamily}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ButtonCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0,12,0" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource AccentPressedColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource AccentHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource SurfaceLow}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="{DynamicResource ButtonMargin}"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerButtonForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource DangerButtonBackgroundColor}"/>
            <Setter Property="Height" Value="{DynamicResource ButtonHeight}"/>
            <Setter Property="MinWidth" Value="{DynamicResource ButtonWidth}"/>
            <Setter Property="FontSize" Value="{DynamicResource ButtonFontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource ButtonFontFamily}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ButtonCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0,12,0" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#BF0000"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource DangerButtonHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource SurfaceLow}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="{DynamicResource ButtonMargin}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="{DynamicResource ButtonHeight}"/>
            <Setter Property="MinWidth" Value="{DynamicResource ButtonWidth}"/>
            <Setter Property="FontSize" Value="{DynamicResource ButtonFontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource ButtonFontFamily}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ButtonCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0,12,0" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource SubtleFillPressedColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource SubtleFillHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="FontSize" Value="{DynamicResource ButtonFontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource ButtonFontFamily}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="{DynamicResource SidebarItemCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillPressedColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBarClearButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="{DynamicResource SearchBarClearButtonFontSize}"/>
            <Setter Property="Content" Value="&#xE711;"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Width" Value="{DynamicResource SearchBarHeight}"/>
            <Setter Property="Height" Value="{DynamicResource SearchBarHeight}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundColor}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillHoverColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppEntryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="{DynamicResource IconButtonSize}"/>
            <Setter Property="Height" Value="{DynamicResource IconButtonSize}"/>
            <Setter Property="Margin" Value="{DynamicResource AppEntryMargin}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundColor}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColor}"/>
            <Setter Property="BorderThickness" Value="{DynamicResource ButtonBorderThickness}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource IconFontSize}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ButtonCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundPressedColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource SurfaceLow}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── NAVIGATION RAIL TOGGLE BUTTON ── -->
        <Style TargetType="{x:Type ToggleButton}">
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            <Setter Property="FontSize" Value="{DynamicResource TabButtonFontSize}"/>
            <Setter Property="Foreground" Value="{DynamicResource NavRailItemForeground}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="{DynamicResource SidebarItemHeight}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource SidebarItemCornerRadius}"
                                Margin="8,2,8,2"
                                Padding="{DynamicResource SidebarItemPadding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource NavRailItemHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource NavRailItemPressed}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource NavRailItemSelected}"/>
                                <Setter Property="Foreground" Value="{DynamicResource NavRailItemSelectedForeground}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── FLUENT TEXTBOX ── -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SearchBoxFocusBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchBoxBorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <ContextMenu.Style>
                            <Style TargetType="ContextMenu">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="4">
                                                <StackPanel>
                                                    <MenuItem Command="Cut" Header="Cut"/>
                                                    <MenuItem Command="Copy" Header="Copy"/>
                                                    <MenuItem Command="Paste" Header="Paste"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ContextMenu.Style>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ButtonCornerRadius}">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource ControlStrongStrokeColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource FocusStrokeColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SearchBoxBorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CaretBrush" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ButtonCornerRadius}">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource ControlStrongStrokeColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource FocusStrokeColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── FLUENT CHECKBOX ── -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Margin="{DynamicResource CheckBoxMargin}">
                            <BulletDecorator>
                                <BulletDecorator.Bullet>
                                    <Grid Width="{DynamicResource CheckBoxBulletDecoratorSize}" Height="{DynamicResource CheckBoxBulletDecoratorSize}">
                                        <Border x:Name="Border"
                                                BorderBrush="{DynamicResource CheckBoxStrokeColor}"
                                                BorderThickness="1.5"
                                                Width="{DynamicResource CheckBoxBulletDecoratorSize}"
                                                Height="{DynamicResource CheckBoxBulletDecoratorSize}"
                                                CornerRadius="{DynamicResource CheckboxCornerRadius}"
                                                SnapsToDevicePixels="True"/>
                                        <Path x:Name="CheckMark"
                                              Stroke="{DynamicResource MainForegroundColor}"
                                              StrokeThickness="2"
                                              Data="M 3 8.5 L 7 12.5 L 14 4.5"
                                              Stretch="Uniform"
                                              Visibility="Collapsed"
                                              Margin="2"/>
                                    </Grid>
                                </BulletDecorator.Bullet>
                                <ContentPresenter Margin="8,0,0,0"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </BulletDecorator>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource CheckBoxFillColor}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource CheckBoxFillColor}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckMark" Property="Stroke" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundColor}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource CheckBoxDisabledColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── FLUENT RADIO BUTTON ── -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" Margin="{DynamicResource CheckBoxMargin}">
                            <Grid Width="{DynamicResource RadioButtonSize}" Height="{DynamicResource RadioButtonSize}">
                                <Ellipse x:Name="OuterCircle"
                                        Stroke="{DynamicResource RadioButtonStrokeColor}"
                                        Fill="Transparent"
                                        StrokeThickness="1.5"
                                        Width="{DynamicResource RadioButtonSize}"
                                        Height="{DynamicResource RadioButtonSize}"
                                        SnapsToDevicePixels="True"/>
                                <Ellipse x:Name="InnerCircle"
                                        Fill="{DynamicResource RadioButtonFillColor}"
                                        Width="8"
                                        Height="8"
                                        Visibility="Collapsed"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                            </Grid>
                            <ContentPresenter Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="InnerCircle" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="OuterCircle" Property="Stroke" Value="{DynamicResource RadioButtonFillColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterCircle" Property="Stroke" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundColor}"/>
                                <Setter TargetName="OuterCircle" Property="Stroke" Value="{DynamicResource CheckBoxDisabledColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── FLUENT TOGGLE SWITCH ── -->
        <Style x:Key="ColorfulToggleSwitchStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid x:Name="toggleSwitch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="1" x:Name="Border"
                                    CornerRadius="{DynamicResource ToggleSwitchCornerRadius}"
                                    BorderThickness="0"
                                    Width="{DynamicResource ToggleSwitchWidth}"
                                    Height="{DynamicResource ToggleSwitchHeight}"
                                    Background="{DynamicResource ToggleButtonOffColor}">
                                <Ellipse x:Name="Ellipse"
                                        Fill="{DynamicResource ToggleButtonThumbColor}"
                                        Stretch="Uniform"
                                        Width="{DynamicResource ToggleThumbSize}"
                                        Height="{DynamicResource ToggleThumbSize}"
                                        Margin="{DynamicResource ToggleThumbMargin}"
                                        HorizontalAlignment="Left"
                                        RenderTransformOrigin="0.5, 0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter TargetName="Ellipse" Property="Fill" Value="{DynamicResource ToggleButtonThumbHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ToggleButtonOffColor}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ToggleButtonOnColor}"/>
                                <Setter TargetName="Ellipse" Property="Fill" Value="{DynamicResource ToggleButtonThumbColor}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Ellipse"
                                                    Storyboard.TargetProperty="Margin"
                                                    To="26,2,2,2" Duration="0:0:0.15">
                                                <ThicknessAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="Ellipse"
                                                    Storyboard.TargetProperty="Margin"
                                                    To="2,2,2,2" Duration="0:0:0.15">
                                                <ThicknessAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── TOGGLE BUTTON STYLE (FOR FEATURE TOGGLES) ── -->
        <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="{DynamicResource ButtonMargin}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundColor}"/>
            <Setter Property="Height" Value="{DynamicResource ButtonHeight}"/>
            <Setter Property="MinWidth" Value="{DynamicResource ButtonWidth}"/>
            <Setter Property="FontSize" Value="{DynamicResource ButtonFontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource ButtonFontFamily}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColor}"/>
            <Setter Property="BorderThickness" Value="{DynamicResource ButtonBorderThickness}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ButtonCornerRadius}">
                            <Grid>
                                <Ellipse x:Name="ToggleDot"
                                        Width="8" Height="16"
                                        Fill="{DynamicResource ToggleButtonOnColor}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,3,5,0"/>
                                <Ellipse x:Name="ToggleDotCircle"
                                        Width="8" Height="8"
                                        Fill="{DynamicResource ButtonForegroundColor}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,3,5,0"
                                        RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Margin="10,2,10,2"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource ButtonBackgroundHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleDotCircle" Property="VerticalAlignment" Value="Bottom"/>
                                <Setter TargetName="ToggleDotCircle" Property="Margin" Value="0,0,5,3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{DynamicResource SurfaceLow}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForegroundColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── FLUENT COMBOBOX ── -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="Height" Value="{DynamicResource ComboboxHeight}"/>
            <Setter Property="MinWidth" Value="{DynamicResource ButtonWidth}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="OuterBorder"
                                    BorderBrush="{DynamicResource ComboBoxBorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource ComboboxCornerRadius}"
                                    Background="{TemplateBinding Background}">
                                <ToggleButton x:Name="ToggleButton"
                                               BorderThickness="0"
                                               IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                               ClickMode="Press">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{TemplateBinding SelectionBoxItem}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                                   Margin="10,0,4,0"/>
                                        <Path Grid.Column="1"
                                              Data="M 0,0 L 8,0 L 4,5 Z"
                                              Fill="{TemplateBinding Foreground}"
                                              Width="8" Height="5"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Stretch="Uniform"
                                              Margin="4,0,10,0"/>
                                    </Grid>
                                </ToggleButton>
                            </Border>
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   Focusable="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource ComboBoxPopupBackgroundColor}"
                                        BorderBrush="{DynamicResource ComboBoxBorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer>
                                        <ItemsPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,2"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource ControlStrongStrokeColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── CARD BORDER STYLE ── -->
        <Style x:Key="BorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeDefaultColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CardCornerRadius}"/>
            <Setter Property="Padding" Value="{DynamicResource CardPadding}"/>
            <Setter Property="Margin" Value="{DynamicResource CardMargin}"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border" BasedOn="{StaticResource BorderStyle}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
        </Style>

        <!-- ── APP ENTRY STYLES ── -->
        <Style x:Key="AppEntryBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeDefaultColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Width" Value="{DynamicResource AppEntryWidth}"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource AppInstallUnselectedColor}"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
        </Style>

        <Style x:Key="AppEntryCheckboxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="18" Height="18" Margin="0,0,8,0">
                                <Border x:Name="CheckBoxBorder"
                                        BorderBrush="{DynamicResource CheckBoxStrokeColor}"
                                        BorderThickness="1.5"
                                        Width="18" Height="18"
                                        CornerRadius="4"/>
                                <Path x:Name="CheckMark"
                                      Stroke="{DynamicResource ToggleButtonOnColor}"
                                      StrokeThickness="2"
                                      Data="M 3 9 L 7 13 L 15 5"
                                      Visibility="Collapsed" Margin="2"/>
                            </Grid>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource CheckBoxFillColor}"/>
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource CheckBoxFillColor}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="CheckMark" Property="Stroke" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppEntryNameStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource AppEntryFontSize}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel>
                            <Grid>
                                <Border Width="45" Height="20"
                                        Background="#555"
                                        CornerRadius="10"
                                        Margin="5,0"/>
                                <Border Name="WPFToggleSwitchButton"
                                        Width="25" Height="25"
                                        Background="#FFF"
                                        CornerRadius="12.5"
                                        HorizontalAlignment="Left"/>
                                <ContentPresenter Name="WPFToggleSwitchContent"
                                                  Margin="10,0,0,0"
                                                  Content="{TemplateBinding Content}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="false">
                                <Trigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="WPFToggleSwitchLeft"/>
                                    <BeginStoryboard x:Name="WPFToggleSwitchRight">
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    Storyboard.TargetName="WPFToggleSwitchButton"
                                                    Duration="0:0:0:0"
                                                    From="0,0,0,0" To="28,0,0,0"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="WPFToggleSwitchButton" Property="Background" Value="#f4f4f4"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Trigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="WPFToggleSwitchRight"/>
                                    <BeginStoryboard x:Name="WPFToggleSwitchLeft">
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    Storyboard.TargetName="WPFToggleSwitchButton"
                                                    Duration="0:0:0:0"
                                                    From="28,0,0,0" To="0,0,0,0"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="WPFToggleSwitchButton" Property="Background" Value="#060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MainForegroundColor}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSize}"/>
            <Setter Property="FontFamily" Value="{DynamicResource FontFamily}"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter Content="{TemplateBinding Header}" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillHoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource DividerStrokeColor}"/>
            <Setter Property="Margin" Value="8,4,8,4"/>
            <Setter Property="Height" Value="1"/>
        </Style>
    </Window.Resources>

    <!-- ── MAIN GRID ── -->
    <Grid Background="{DynamicResource WindowBackground}" Name="WPFMainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource TitleBarHeight}"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════════
             ROW 0: TITLE BAR
             ════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Background="{DynamicResource SurfaceLow}" Name="NavDockPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo + App Name -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Name="NavLogoPanel" Margin="16,0,0,0">
                <!-- Logo injected dynamically by PS -->
            </StackPanel>

            <!-- Drag area -->
            <Grid Grid.Column="1"/>

            <!-- Title Bar Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,4,0">

                <!-- Theme Button -->
                <Button Name="ThemeButton"
                        Style="{StaticResource HoverButtonStyle}"
                        Width="34" Height="34"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Content="&#xE708;"
                        ToolTip="Change Theme"
                        Margin="2,0"/>
                <Popup Name="ThemePopup"
                       IsOpen="False"
                       PlacementTarget="{Binding ElementName=ThemeButton}"
                       Placement="Bottom"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="4"
                            MinWidth="140">
                        <StackPanel>
                            <MenuItem Name="AutoThemeMenuItem" Header="Auto (Follow System)" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Name="DarkThemeMenuItem" Header="Dark" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Name="LightThemeMenuItem" Header="Light" Style="{StaticResource MenuItemStyle}"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Font Scaling Button -->
                <Button Name="FontScalingButton"
                        Style="{StaticResource HoverButtonStyle}"
                        Width="34" Height="34"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Content="&#xE8D3;"
                        ToolTip="Adjust Font Scaling"
                        Margin="2,0"/>
                <Popup Name="FontScalingPopup"
                       IsOpen="False"
                       PlacementTarget="{Binding ElementName=FontScalingButton}"
                       Placement="Bottom"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16"
                            MinWidth="240">
                        <StackPanel>
                            <TextBlock Text="Font Scaling"
                                       FontSize="{DynamicResource SubHeaderFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MainForegroundColor}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <Separator Background="{DynamicResource DividerStrokeColor}" Margin="0,0,0,12" Height="1"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="A" FontSize="10" Foreground="{DynamicResource SecondaryForegroundColor}" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1"
                                        Name="FontScalingSlider"
                                        Minimum="0.75" Maximum="2.0"
                                        Value="1.0"
                                        TickFrequency="0.25"
                                        TickPlacement="BottomRight"
                                        IsSnapToTickEnabled="True"
                                        Margin="10,0"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="A" FontSize="18" Foreground="{DynamicResource SecondaryForegroundColor}" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Name="FontScalingValue"
                                       Text="100%"
                                       FontSize="{DynamicResource FontSize}"
                                       Foreground="{DynamicResource AccentColor}"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Margin="0,8,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Button Name="FontScalingResetButton"
                                        Content="Reset"
                                        MinWidth="80"
                                        Height="30"
                                        Margin="4,0"/>
                                <Button Name="FontScalingApplyButton"
                                        Content="Apply"
                                        MinWidth="80"
                                        Height="30"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="4,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Settings Button -->
                <Button Name="SettingsButton"
                        Style="{StaticResource HoverButtonStyle}"
                        Width="34" Height="34"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Content="&#xE713;"
                        ToolTip="Settings"
                        Margin="2,0"/>
                <Popup Name="SettingsPopup"
                       IsOpen="False"
                       PlacementTarget="{Binding ElementName=SettingsButton}"
                       Placement="Bottom"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="4"
                            MinWidth="160">
                        <StackPanel>
                            <MenuItem Name="ImportMenuItem" Header="Import Configuration" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Name="ExportMenuItem" Header="Export Configuration" Style="{StaticResource MenuItemStyle}"/>
                            <Separator Background="{DynamicResource DividerStrokeColor}" Margin="8,4" Height="1"/>
                            <MenuItem Name="AboutMenuItem" Header="About" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Name="DocumentationMenuItem" Header="Documentation" Style="{StaticResource MenuItemStyle}"/>
                            <MenuItem Name="SponsorMenuItem" Header="Sponsors" Style="{StaticResource MenuItemStyle}"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Window Controls -->
                <Separator Style="{StaticResource SeparatorStyle}" Width="1" Height="20" Margin="8,0,8,0"/>

                <Button Name="WPFMinimizeButton"
                        Style="{StaticResource HoverButtonStyle}"
                        Width="46" Height="36"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="10"
                        Content="&#xE921;"/>
                <Button Name="WPFCloseButton"
                        Style="{StaticResource HoverButtonStyle}"
                        Width="46" Height="36"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="10"
                        Content="&#xE8BB;"/>
            </StackPanel>
        </Grid>

        <!-- ════════════════════════════════════════════════════════════════
             ROW 1: MAIN CONTENT (Nav Rail + Content Area)
             ════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{DynamicResource NavRailWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT NAVIGATION RAIL ── -->
            <Border Grid.Column="0" Background="{DynamicResource NavRailBackground}" BorderBrush="{DynamicResource DividerStrokeColor}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Offline Banner -->
                    <Border Name="WPFOfflineBanner" Grid.Row="0" Background="{DynamicResource OfflineBannerBackground}" Visibility="Collapsed" Padding="12,8">
                        <TextBlock Text="&#x26A0; Offline Mode" Foreground="White" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Navigation Items -->
                    <StackPanel Grid.Row="1" Margin="0,12,0,0">
                        <ToggleButton Name="WPFTab1BT" Height="{DynamicResource SidebarItemHeight}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="12,0,12,0"/>
                                <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource TabButtonFontSize}">
                                    <Underline>A</Underline>pplications
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Name="WPFTab2BT" Height="{DynamicResource SidebarItemHeight}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="12,0,12,0"/>
                                <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource TabButtonFontSize}">
                                    <Underline>T</Underline>weaks
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Name="WPFTab3BT" Height="{DynamicResource SidebarItemHeight}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="12,0,12,0"/>
                                <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource TabButtonFontSize}">
                                    <Underline>C</Underline>onfig
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Name="WPFTab4BT" Height="{DynamicResource SidebarItemHeight}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="12,0,12,0"/>
                                <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource TabButtonFontSize}">
                                    <Underline>U</Underline>pdates
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Name="WPFTab5BT" Height="{DynamicResource SidebarItemHeight}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7B7;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="12,0,12,0"/>
                                <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource TabButtonFontSize}">
                                    <Underline>W</Underline>in11 Creator
                                </TextBlock>
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>

                    <!-- Version info at bottom -->
                    <TextBlock Grid.Row="2"
                               FontSize="11"
                               Foreground="{DynamicResource TertiaryForegroundColor}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"
                               Name="WPFVersionText"/>
                </Grid>
            </Border>

            <!-- ── RIGHT CONTENT AREA ── -->
            <Grid Grid.Column="1" Background="{DynamicResource WindowBackground}">
                <!-- Search Bar Row -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Bar (visible only on Install and Tweaks tabs) -->
                <Border Grid.Row="0" Background="{DynamicResource Transparent}" Padding="16,10" Visibility="Visible" Name="WPFSearchBarArea">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Input -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource SearchBoxBackground}"
                                CornerRadius="6"
                                Height="{DynamicResource SearchBarHeight}"
                                MaxWidth="400"
                                MinWidth="100"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                        Name="SearchBar"
                                        FontSize="{DynamicResource SearchBarTextBoxFontSize}"
                                        Width="200"
                                        Padding="0,6,0,0"
                                        BorderThickness="0,0,0,1"
                                        VerticalAlignment="Center"
                                        ToolTip="Press Ctrl-F and type to search. Press Esc to reset."/>
                                <TextBlock Grid.Column="1"
                                        Text="&#xE721;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="14"
                                        VerticalAlignment="Center"
                                        Padding="10,0,6,0"/>
                            </Grid>
                        </Border>
                                <Button Grid.Column="2"
                                        Name="SearchBarClearButton"
                                        Style="{StaticResource SearchBarClearButtonStyle}"
                                        Visibility="Collapsed"/>

                        <!-- Action buttons (selected apps, etc) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Tab Content -->
                <TabControl Grid.Row="1"
                            Name="WPFTabNav"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            SelectedIndex="0">
                    <TabControl.Resources>
                        <Style TargetType="TabPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- ════════════════════════════════════════════════════
                         TAB 1: INSTALL (Applications)
                         ════════════════════════════════════════════════════ -->
                    <TabItem Header="Install" Visibility="Collapsed" Name="WPFTab1">
                        <Grid Margin="{DynamicResource TabContentMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Sidebar: App Categories -->
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,16,0">
                                <Grid Name="appscategory" VerticalAlignment="Stretch"/>
                            </Border>

                            <!-- Main: App Panel -->
                            <Grid Grid.Column="1" Name="appspanel" VerticalAlignment="Stretch"/>
                        </Grid>
                    </TabItem>

                    <!-- ════════════════════════════════════════════════════
                         TAB 2: TWEAKS
                         ════════════════════════════════════════════════════ -->
                    <TabItem Header="Tweaks" Visibility="Collapsed" Name="WPFTab2">
                        <Grid Margin="{DynamicResource TabContentMargin}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Recommended Selections -->
                            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Recommended Selections"
                                               Style="{StaticResource SectionHeaderTextStyle}"/>
                                    <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Name="WPFstandard" Content="Standard" MinWidth="100" Height="30" Margin="0,0,8,0"/>
                                        <Button Name="WPFminimal" Content="Minimal" MinWidth="100" Height="30" Margin="0,0,8,0"/>
                                        <Button Name="WPFAdvanced" Content="Advanced" MinWidth="100" Height="30" Margin="0,0,8,0"/>
                                        <Button Name="WPFClearTweaksSelection" Content="Clear" MinWidth="80" Height="30" Margin="0,0,8,0"/>
                                        <Button Name="WPFGetInstalledTweaks" Content="Get Installed Tweaks" MinWidth="140" Height="30" Style="{StaticResource PrimaryButtonStyle}"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Tweak Items -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <Grid Name="tweakspanel"/>
                            </ScrollViewer>

                            <!-- Bottom Bar: Run/Undo + Note -->
                            <Grid Grid.Row="2" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                                    <TextBlock Text="Hover over items for descriptions. Recommended selections are for normal users. If unsure, do NOT check anything else!"
                                               Foreground="{DynamicResource SecondaryForegroundColor}"
                                               TextWrapping="Wrap"
                                               FontSize="12"/>
                                </Border>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Name="WPFTweaksbutton"
                                            Content="Run Tweaks"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            MinWidth="120" Height="34"
                                            Margin="0,0,8,0"/>
                                    <Button Name="WPFUndoall"
                                            Content="Undo Selected"
                                            MinWidth="120" Height="34"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <!-- ════════════════════════════════════════════════════
                         TAB 3: CONFIG (Features + Fixes + More)
                         ════════════════════════════════════════════════════ -->
                    <TabItem Header="Config" Visibility="Collapsed" Name="WPFTab3">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="{DynamicResource TabContentMargin}">
                            <Grid Name="featurespanel"/>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ════════════════════════════════════════════════════
                         TAB 4: UPDATES
                         ════════════════════════════════════════════════════ -->
                    <TabItem Header="Updates" Visibility="Collapsed" Name="WPFTab4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="{DynamicResource TabContentMargin}">
                            <StackPanel>
                                <!-- Three Update Mode Cards -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Default Settings -->
                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="4">
                                        <StackPanel>
                                            <Button Name="WPFUpdatesdefault"
                                                    Content="Default Settings"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                   
                                                    Margin="0,0,0,12"/>
                                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MainForegroundColor}" FontSize="13">
                                                <Run FontWeight="SemiBold">Default Windows Update Configuration</Run>
                                                <LineBreak/>
                                                - No modifications to defaults
                                                <LineBreak/>
                                                - Removes custom update settings
                                                <LineBreak/><LineBreak/>
                                                <Run FontStyle="Italic" FontSize="11" Foreground="{DynamicResource SecondaryForegroundColor}">Resets to out-of-box settings.</Run>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Security Settings -->
                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4">
                                        <StackPanel>
                                            <Button Name="WPFUpdatessecurity"
                                                    Content="Security Settings"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                   
                                                    Margin="0,0,0,12"/>
                                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MainForegroundColor}" FontSize="13">
                                                <Run FontWeight="SemiBold">Balanced Security Configuration</Run>
                                                <LineBreak/>
                                                - Feature updates: 365 day delay
                                                <LineBreak/>
                                                - Security updates: 4 day delay
                                                <LineBreak/>
                                                - No driver updates via WU
                                                <LineBreak/><LineBreak/>
                                                <Run FontStyle="Italic" FontSize="11" Foreground="{DynamicResource SecondaryForegroundColor}">Pro systems only (group policy).</Run>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Disable Updates -->
                                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="4">
                                        <StackPanel>
                                            <Button Name="WPFUpdatesdisable"
                                                    Content="Disable All Updates"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                   
                                                    Margin="0,0,0,12"/>
                                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MainForegroundColor}" FontSize="13">
                                                <Run FontWeight="SemiBold" Foreground="{DynamicResource ErrorColor}">!! Not Recommended !!</Run>
                                                <LineBreak/>
                                                - Disables ALL Windows Updates
                                                <LineBreak/>
                                                - Increases security risks
                                                <LineBreak/>
                                                - Only for isolated systems
                                                <LineBreak/><LineBreak/>
                                                <Run FontStyle="Italic" FontSize="11" Foreground="{DynamicResource ErrorColor}">Your system will be vulnerable!</Run>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Updates Panel (future) -->
                                <Grid Name="updatespanel" Margin="0,16,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ════════════════════════════════════════════════════
                         TAB 5: Win11 Creator
                         ════════════════════════════════════════════════════ -->
                    <TabItem Header="Win11ISO" Visibility="Collapsed" Name="WPFTab5">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="{DynamicResource TabContentMargin}">
                            <Grid Name="Win11ISOPanel">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Steps 1-4 -->
                                <StackPanel Grid.Row="0">

                                    <!-- ─── STEP 1 : Select Windows 11 ISO ─────────────── -->
                                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                        <Grid Name="WPFWin11ISOSelectSection">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Left: File Selector -->
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                <TextBlock Style="{StaticResource SubHeaderTextStyle}" Margin="0,0,0,8">
                                                    Step 1 - Select Windows 11 ISO
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                                           Foreground="{DynamicResource SecondaryForegroundColor}">
                                                    Browse to your locally saved Windows 11 ISO file. Only official ISOs from Microsoft are supported.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" FontStyle="Italic"
                                                           Foreground="{DynamicResource SecondaryForegroundColor}">
                                                    <Run FontWeight="SemiBold">NOTE:</Run> Only for fresh and new Windows installs.
                                                </TextBlock>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Name="WPFWin11ISOPath"
                                                             IsReadOnly="True"
                                                             Padding="10,6"
                                                             Margin="0,0,8,0"
                                                             Text="No ISO selected..."/>
                                                    <Button Grid.Column="1"
                                                            Name="WPFWin11ISOBrowseButton"
                                                            Content="Browse"
                                                            Padding="16,0"/>
                                                </Grid>
                                                <TextBlock Name="WPFWin11ISOFileInfo"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap"
                                                           Visibility="Collapsed"/>
                                            </StackPanel>

                                            <!-- Right: Download guidance -->
                                            <Border Grid.Column="1"
                                                    Style="{StaticResource CardStyle}"
                                                    Background="{DynamicResource SurfaceLow}">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource WarningColor}" Margin="0,0,0,10">
                                                        Use an official Microsoft ISO
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                                                               Foreground="{DynamicResource SecondaryForegroundColor}">
                                                        Download directly from Microsoft.com. Third-party or modified images may produce broken results.
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                                               Foreground="{DynamicResource SecondaryForegroundColor}">
                                                        On the Microsoft download page, choose:
                                                    </TextBlock>
                                                    <TextBlock Margin="12,0,0,12" Foreground="{DynamicResource SecondaryForegroundColor}">
                                                        - Edition: Windows 11
                                                        <LineBreak/>- Language: your preference
                                                        <LineBreak/>- Architecture: 64-bit (x64)
                                                    </TextBlock>
                                                    <Button Name="WPFWin11ISODownloadLink"
                                                            Content="Open Microsoft Download Page"
                                                            Padding="16,0"
                                                            HorizontalAlignment="Left"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- ─── STEP 2 : Mount & Verify ISO ──────────────────── -->
                                    <Border Name="WPFWin11ISOMountSection"
                                            Style="{StaticResource CardStyle}"
                                            Margin="0,0,0,16"
                                            Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Top">
                                                <TextBlock Style="{StaticResource SubHeaderTextStyle}" Margin="0,0,0,8">
                                                    Step 2 - Mount &amp; Verify ISO
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" MaxWidth="320"
                                                           Foreground="{DynamicResource SecondaryForegroundColor}">
                                                    Mount the ISO and confirm it contains a valid Windows 11 install.wim before modifications.
                                                </TextBlock>
                                                <Button Name="WPFWin11ISOMountButton"
                                                        Content="Mount &amp; Verify ISO"
                                                        Padding="16,0"
                                                        Style="{StaticResource PrimaryButtonStyle}"/>
                                                <CheckBox Name="WPFWin11ISOInjectDrivers"
                                                          Content="Inject current system drivers"
                                                          IsChecked="False"
                                                          Margin="0,12,0,0"
                                                          ToolTip="Exports drivers from this machine and injects them into install.wim and boot.wim. Recommended for unsupported NVMe or network controllers."/>
                                            </StackPanel>

                                            <!-- Verification results -->
                                            <Border Grid.Column="1"
                                                    Name="WPFWin11ISOVerifyResultPanel"
                                                    Style="{StaticResource CardStyle}"
                                                    Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock Name="WPFWin11ISOMountDriveLetter" Margin="0,0,0,4"/>
                                                    <TextBlock Name="WPFWin11ISOArchLabel" Margin="0,0,0,4"/>
                                                    <TextBlock FontWeight="SemiBold" Margin="0,8,0,4">Select Edition:</TextBlock>
                                                    <ComboBox Name="WPFWin11ISOEditionComboBox"
                                                              HorizontalAlignment="Left"
                                                              MinWidth="200"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- ─── STEP 3 : Modify install.wim ───────────────────── -->
                                    <Border Name="WPFWin11ISOModifySection"
                                            Style="{StaticResource CardStyle}"
                                            Margin="0,0,0,16"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SubHeaderTextStyle}" Margin="0,0,0,8">
                                                Step 3 - Modify install.wim
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                                                       Foreground="{DynamicResource SecondaryForegroundColor}">
                                                The ISO contents will be extracted, install.wim modified (components removed, tweaks applied), and the result repackaged. This may take several minutes.
                                            </TextBlock>
                                            <Button Name="WPFWin11ISOModifyButton"
                                                    Content="Run Windows ISO Modification and Creator"
                                                    Padding="16,0"
                                                    Style="{StaticResource PrimaryButtonStyle}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ─── STEP 4 : Output Options ───────────────────────── -->
                                    <Border Name="WPFWin11ISOOutputSection"
                                            Style="{StaticResource CardStyle}"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <!-- Title + Clean & Reset -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Style="{StaticResource SubHeaderTextStyle}" VerticalAlignment="Center">
                                                    Step 4 - Output: What would you like to do?
                                                </TextBlock>
                                                <Button Grid.Column="1"
                                                        Name="WPFWin11ISOCleanResetButton"
                                                        Content="Clean &amp; Reset"
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        Padding="16,0"
                                                        ToolTip="Delete temporary files and reset to Step 1"/>
                                            </Grid>

                                            <!-- Choice prompt -->
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Name="WPFWin11ISOChooseISOButton"
                                                        Content="Save as ISO File"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Padding="16,0"
                                                        Margin="0,0,8,0"/>
                                                <Button Grid.Column="1"
                                                        Name="WPFWin11ISOChooseUSBButton"
                                                        Content="Write to USB Drive"
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        Padding="16,0"
                                                        Margin="8,0,0,0"/>
                                            </Grid>

                                            <!-- USB write sub-panel -->
                                            <Border Name="WPFWin11ISOOptionUSB"
                                                    Style="{StaticResource CardStyle}"
                                                    Visibility="Collapsed"
                                                    Background="{DynamicResource SurfaceLow}">
                                                <StackPanel>
                                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" Foreground="{DynamicResource ErrorColor}">
                                                        <Run FontWeight="SemiBold">!! All data on the selected USB drive will be permanently erased !!</Run>
                                                        <LineBreak/>
                                                        Select a removable USB drive below, then click Erase &amp; Write.
                                                    </TextBlock>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox Grid.Column="0"
                                                                  Name="WPFWin11ISOUSBDriveComboBox"
                                                                  MinWidth="200"
                                                                  Margin="0,0,8,0"/>
                                                        <Button Grid.Column="1"
                                                                Name="WPFWin11ISORefreshUSBButton"
                                                                Content="Refresh"
                                                                Padding="12,0"/>
                                                    </Grid>
                                                    <Button Name="WPFWin11ISOWriteUSBButton"
                                                            Content="Erase &amp; Write to USB"
                                                            Style="{StaticResource DangerButtonStyle}"
                                                            Padding="16,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Status Log -->
                                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Style="{StaticResource SubHeaderTextStyle}" Margin="0,0,0,8">
                                            Status Log
                                        </TextBlock>
                                        <TextBox Grid.Row="1"
                                                 Name="WPFWin11ISOStatusLog"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Visible"
                                                 VerticalAlignment="Stretch"
                                                 MinHeight="120"
                                                 Padding="8"
                                                 FontFamily="{DynamicResource MonospaceFontFamily}"
                                                 FontSize="12"
                                                 Text="Ready. Please select a Windows 11 ISO to begin."/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Grid>
</Window>
